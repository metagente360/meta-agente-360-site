{
  "name": "BlogPost",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo principal do artigo"
    },
    "seo_title": {
      "type": "string",
      "description": "T\u00edtulo SEO do artigo"
    },
    "slug": {
      "type": "string",
      "description": "URL amig\u00e1vel do artigo"
    },
    "excerpt": {
      "type": "string",
      "description": "Resumo/excerpt do artigo"
    },
    "meta_description": {
      "type": "string",
      "description": "Meta description para SEO"
    },
    "content": {
      "type": "string",
      "description": "Conte\u00fado completo em Markdown"
    },
    "author": {
      "type": "string",
      "description": "Autor do artigo"
    },
    "tag": {
      "type": "string",
      "description": "Tag principal do artigo"
    },
    "category": {
      "type": "string",
      "description": "Categoria do artigo"
    },
    "keyword": {
      "type": "string",
      "description": "Palavra-chave principal"
    },
    "read_time": {
      "type": "string",
      "description": "Tempo de leitura estimado"
    },
    "image": {
      "type": "string",
      "description": "URL da imagem de capa"
    },
    "accent": {
      "type": "string",
      "description": "Classe de cor de destaque (ex: text-brand-blue)"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published"
      ],
      "default": "draft",
      "description": "Status de publica\u00e7\u00e3o"
    }
  },
  "required": [
    "title",
    "slug",
    "status"
  ]
}