{
  "name": "CaseSolucao",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome da pessoa do case"
    },
    "especialidade": {
      "type": "string",
      "description": "Cargo ou especialidade"
    },
    "foto": {
      "type": "string",
      "description": "URL da foto"
    },
    "agente": {
      "type": "string",
      "description": "Nome do agente utilizado"
    },
    "resultado": {
      "type": "string",
      "description": "Resultado alcan\u00e7ado com o agente"
    },
    "status": {
      "type": "string",
      "enum": [
        "ativo",
        "inativo"
      ],
      "default": "ativo"
    }
  },
  "required": [
    "nome",
    "especialidade",
    "agente",
    "resultado"
  ]
}